        "print(\"Question 2: What is the difference between WHERE and HAVING? Write one example of each using the students table.\")\n",
        "print(\"Difference between WHERE and HAVING:\")\n",
        "print(\"  - WHERE clause is used to filter individual rows based on a specified condition *before* grouping.\")\n",
        "print(\"  - HAVING clause is used to filter groups of rows based on a specified condition, typically involving aggregate functions, *after* grouping.\")\n",
        "\n",
        "print(\"\\nExample using WHERE (filtering individual rows by math_score > 80):\")\n",
        "query_where = \"\"\"\n",
        "SELECT name, math_score\n",
        "FROM students\n",
        "WHERE math_score > 80\n",
        "ORDER BY math_score DESC\n",
        "\"\"\"\n",
        "run_query(query_where, \"Students with Math Score > 80 (WHERE example)\")\n",
        "\n",
        "print(\"\\nExample using HAVING (filtering groups by average math_score > 70):\")\n",
        "query_having = \"\"\"\n",
