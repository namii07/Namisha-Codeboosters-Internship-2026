        "\n",
        "\n",
        "chart1_sql = \"\"\"\n",
        "SELECT department,\n",
        "       ROUND(AVG(math_score), 1) AS avg_math\n",
        "FROM students\n",
        "GROUP BY department\n",
        "ORDER BY avg_math DESC\n",
